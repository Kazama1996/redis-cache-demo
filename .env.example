# =============================================
# Spring Boot
# =============================================

SPRING_PROFILES_ACTIVE=local

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=redis_cache_demo
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# Connection pool
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=5
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000

# JPA
JPA_DDL_AUTO=none
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=true

# Snowflake ID
WORKER_ID=1
DATACENTER_ID=1

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DATABASE=0
REDISSON_POOL_SIZE=64
REDISSON_MIN_IDLE=10

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9094

# Seckill
SECKILL_WARMUP_MINUTES_BEFORE=1

# Logging
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
LOG_LEVEL_SQL=WARN
LOG_LEVEL_SQL_BINDER=INFO
LOG_LEVEL_REDISSON=WARN

# Server
SERVER_PORT=8080
SERVER_CONTEXT_PATH=/

# =============================================
# Docker Compose only
# =============================================

POSTGRES_USER=your_db_username
POSTGRES_PASSWORD=your_db_password
REDIS_PASSWORD=your_redis_password
PGADMIN_EMAIL=your_pgadmin_email
PGADMIN_PASSWORD=your_pgadmin_password
